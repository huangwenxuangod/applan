# 复制为 .env 后填入真实值：cp .env.example .env
# DeepSeek 申请地址：https://platform.deepseek.com （新用户有免费额度）

DEEPSEEK_API_KEY=sk-your-real-key-here
# 注意：DeepSeek 的 OpenAI 兼容基址带 /v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MODEL=deepseek-chat
PORT=8787

# 可选：设了之后要求客户端带 Bearer；内网可留空免鉴权
# PROXY_API_KEY=your-proxy-key

# 单设备管理接口认证令牌。生成一段随机字符串，并在手机端配置相同值。
DEVICE_TOKEN=replace-with-a-long-random-token
# SQLite 策略和审计存储路径（Compose 已挂载 ./data）
STATE_DB=/app/data/state.db
# 仅本机调试时临时设为 true；生产环境必须保持 false。
ALLOW_INSECURE_LOCAL=false

# 记忆（SOUL 第5条：把用户反复用的借口记到 applan.md，下次引用「你第N次」）
# 默认 ./applan.md，容器内路径 /app/applan.md，compose 已挂成可写
# MEMORY_FILE=/app/applan.md
# 关闭记忆写回（省一次上游调用/轮）：设为 false。读注入仍生效
# ENABLE_MEMORY_WRITE=true

# 想换其它 OpenAI 兼容模型（如本地 ollama）改下面两行即可：
# DEEPSEEK_BASE_URL=http://host.docker.internal:11434/v1
# MODEL=qwen2.5:7b
